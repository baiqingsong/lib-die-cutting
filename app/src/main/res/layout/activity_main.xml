<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="12dp">

    <TextView android:id="@+id/tv_status" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="状态: 未初始化"
        android:textSize="18sp" android:textStyle="bold" android:padding="6dp" />
    <TextView android:id="@+id/tv_progress" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="进度: 0%"
        android:textSize="14sp" android:padding="4dp" />

    <!-- Row 1 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="6dp">
        <Button android:id="@+id/btn_init" android:text="初始化"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        <Button android:id="@+id/btn_fw" android:text="固件版本"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false"/>
        <Button android:id="@+id/btn_release" android:text="释放SDK"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false"/>
    </LinearLayout>
    <!-- Row 2 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="6dp">
        <Button android:id="@+id/btn_left" android:text="左移"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false"/>
        <Button android:id="@+id/btn_right" android:text="右移"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false"/>
        <Button android:id="@+id/btn_down" android:text="退纸"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false"/>
        <Button android:id="@+id/btn_stop" android:text="停止"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false"/>
    </LinearLayout>
    <!-- Row 3 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="6dp">
        <Button android:id="@+id/btn_cut" android:text="普通切割"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false"/>
        <Button android:id="@+id/btn_profile" android:text="肖像切割"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false"/>
        <Button android:id="@+id/btn_print" android:text="仅打印"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false"/>
    </LinearLayout>
    <!-- Row 3.5 相框裁剪 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="6dp">
        <Button android:id="@+id/btn_frame_cut" android:text="相框裁剪"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:enabled="false" android:backgroundTint="#4CAF50" />
    </LinearLayout>
    <!-- Row 4 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="6dp">
        <Button android:id="@+id/btn_reboot" android:text="重启"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false"/>
        <Button android:id="@+id/btn_quit" android:text="入口退纸"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false"/>
        <Button android:id="@+id/btn_enter" android:text="进纸"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false"/>
        <Button android:id="@+id/btn_calib" android:text="校准"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false"/>
    </LinearLayout>

    <TextView android:id="@+id/tv_log" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="日志:\n" android:textSize="11sp"
        android:fontFamily="monospace" android:padding="6dp" android:layout_marginTop="6dp"
        android:background="#F0F0F0" />

    <Button android:id="@+id/btn_process_img" android:text="图片处理: frame → finish"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:backgroundTint="#FF9800" />

</LinearLayout>
</ScrollView>
